[Unit]
Description=Atsawin AI FastAPI Backend
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory=/root/Atsawin-AI-Core/backend
Environment=PYTHONPATH=/root/Atsawin-AI-Core/backend
ExecStart=/root/Atsawin-AI-Core/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
